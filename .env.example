# API authentication
API_TOKEN=change-me-to-a-secure-random-token

# Server
PORT=3000
HOST=0.0.0.0

# Discord webhook (required for job reporting)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Accounts: email:password pairs, comma-separated
# ACCOUNTS=account1@example.com:password1,account2@example.com:password2
ACCOUNTS=

# Proxies: host:port:username:password, comma-separated
# PROXIES=74.81.32.177:7700:user:pass,74.81.32.179:5593:user:pass
PROXIES=

# Default sale time (JST, HH:MM:SS). Used when job does not specify saleTime.
DEFAULT_SALE_TIME=09:30:00

# Minutes before sale to pre-login accounts (randomized between min and max)
PRE_LOGIN_MIN_MINUTES=5
PRE_LOGIN_MAX_MINUTES=10

# Max parallel browser contexts (target: 50)
MAX_PARALLEL_JOBS=50

# Browser settings
HEADLESS=true
NAVIGATION_TIMEOUT_MS=30000
ACTION_TIMEOUT_MS=10000

# Monitor mode poll interval (ms)
MONITOR_POLL_INTERVAL_MS=500

# Optional: credit card security code for accounts without saved cards
# SECURITY_CODE=
